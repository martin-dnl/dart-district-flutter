NODE_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8081

# Existing PostgreSQL container on same Docker network
POSTGRES_HOST=dartdistrict-postgres-prod
POSTGRES_PORT=5432
POSTGRES_USER=dart_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dart_district

JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

CORS_ORIGIN=https://dart-district.fr,https://www.dart-district.fr

GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_IDS=
GOOGLE_OAUTH_REQUIRED_CLIENT_IDS=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dart-district.fr/api/v1/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=https://dart-district.fr/api/v1/auth/apple/callback

WS_PORT=8081
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Docker network shared with Caddy and PostgreSQL
DOCKER_NETWORK_NAME=dartdistrict_default
